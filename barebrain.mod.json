{
  "schema": 1,
  "id": "tool-tts",
  "name": "WonderEcho Voice",
  "version": "0.1.5",
  "type": "tool",
  "description": "Control a Hiwonder WonderEcho CI1302 module over I2C, play preconfigured phrases, read recognition IDs, and inject selected voice commands into the BareBrain agent.",
  "targets": ["esp32s3"],
  "barebrain_min": "0.1.0",
  "barebrain_max": "0.x",
  "sources": [
    "src/mod_tool_tts.c",
    "src/tool_tts.c"
  ],
  "headers": [
    "src/tool_tts.h"
  ],
  "dependencies": [
    "core.tool_registry",
    "core.message_bus"
  ],
  "conflicts": [],
  "permissions": ["gpio.write", "i2c.read", "i2c.write"],
  "idf_components": ["esp_driver_i2c"],
  "tools": [
    "tts_status",
    "tts_speak",
    "tts_read_recognition"
  ],
  "services": ["voice_command_listener"],
  "resources": {
    "tasks": 1,
    "gpio": ["configurable"],
    "i2c": ["configurable"],
    "psram_bytes_hint": 16384,
    "flash_bytes_hint": 57344
  },
  "config_schema": {
    "tts.i2c_sda": {
      "type": "gpio",
      "label": "I2C SDA",
      "required": true
    },
    "tts.i2c_scl": {
      "type": "gpio",
      "label": "I2C SCL",
      "required": true
    }
  },
  "hardware": {
    "module": "Hiwonder WonderEcho CI1302 voice interaction module",
    "interface": "i2c",
    "i2c_address": "0x34",
    "recognition_register": "0x64",
    "broadcast_register": "0x6E",
    "voice_command_map": {
      "0x01": "query_weather",
      "0x02": "play_music",
      "0x08": "create_timer",
      "0x09": "query_memory"
    },
    "power": [
      {"module_pin": "5V", "board_pin": "5V"},
      {"module_pin": "GND", "board_pin": "GND"}
    ]
  }
}
